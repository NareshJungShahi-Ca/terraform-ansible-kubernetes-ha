global
    log /dev/log local0
    maxconn 2048

defaults
    log global
    mode tcp
    timeout connect 10s
    timeout client 1m
    timeout server 1m

frontend k8s_api
    bind *:{{ haproxy_port }}
    default_backend k8s_masters

backend k8s_masters
    balance roundrobin
{% for master in masters %}
    server {{ master.name }} {{ master.ip }}:6443 check
{% endfor %}
